# AutoLenis — Environment Variables Example
# Copy this file to .env.local and fill in the values.
# Never commit .env.local or any file with real secrets.

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/autolenis?schema=public
DIRECT_URL=postgresql://user:password@localhost:5432/autolenis

# Vercel Postgres / Supabase pooler (used by Prisma in production)
POSTGRES_PRISMA_URL=postgresql://user:password@localhost:5432/autolenis?schema=public
POSTGRES_URL_NON_POOLING=postgresql://user:password@localhost:5432/autolenis

# ─── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Auth / JWT ───────────────────────────────────────────────────────────────
JWT_SECRET=change-me-at-least-32-chars
NEXTAUTH_SECRET=change-me-at-least-32-chars
CSRF_SECRET=change-me-at-least-32-chars

# ─── Encryption ───────────────────────────────────────────────────────────────
# Used to encrypt PII such as SSN at rest.
PREQUAL_ENCRYPTION_KEY=change-me-32-hex-chars

# ─── Cron ─────────────────────────────────────────────────────────────────────
CRON_SECRET=change-me-at-least-32-chars

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_UNSUBSCRIBE_SECRET=change-me-at-least-32-chars

# ─── Stripe ───────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# ─── DocuSign ─────────────────────────────────────────────────────────────────
DOCUSIGN_CLIENT_ID=your-docusign-client-id
DOCUSIGN_CLIENT_SECRET=your-docusign-client-secret
DOCUSIGN_PRIVATE_KEY_BASE64=your-base64-encoded-private-key
DOCUSIGN_ACCOUNT_ID=your-docusign-account-id
DOCUSIGN_USER_ID=your-docusign-user-id
DOCUSIGN_DEALER_TEMPLATE_ID=your-template-id

# ─── MicroBilt iPredict ───────────────────────────────────────────────────────
MICROBILT_CLIENT_ID=your-microbilt-client-id
MICROBILT_CLIENT_SECRET=your-microbilt-client-secret
MICROBILT_IPREDICT_BASE_URL=https://sandbox.microbilt.com/ipredict/v1

# ─── AI (Groq) ────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# ─── Inventory ────────────────────────────────────────────────────────────────
MARKETCHECK_API_KEY=your-marketcheck-api-key

# ─── Application ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
MAINTENANCE_MODE=false
CURRENT_TERMS_VERSION=1

# ─── Redis — Distributed Rate Limiting ───────────────────────────────────────
# Optional. When set, rate limiting uses Redis for distributed rate limiting
# across multiple instances. Falls back to in-memory when not configured.
# Required for production deployments with multiple Vercel instances.
REDIS_URL=redis://localhost:6379

# ─── Node ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
